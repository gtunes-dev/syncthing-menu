<plist version="1.0">
<dict>
	<!-- App Sandbox is intentionally NOT enabled: Syncthing needs broad
	     filesystem access, which the sandbox would prevent. This is why the
	     app is distributed with Developer ID + notarization, not via the
	     Mac App Store. -->
	<!-- Add hardened-runtime exceptions here only if notarization later
	     requires them. -->
</dict>
</plist>
