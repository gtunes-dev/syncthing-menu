# macOS
.DS_Store

# Xcode — per-user state and build products
build/
DerivedData/
*.xcuserstate
xcuserdata/
*.xcscmblueprint
*.xccheckout
*.moved-aside

# Build server (xcode-build-server output — generated; regenerate with `xcode-build-server config -project SyncthingMenu.xcodeproj -scheme SyncthingMenu`)
buildServer.json

# Swift Package Manager (in case it's added later)
.build/
.swiftpm/

# Secrets & signing material — MUST never be committed
*.p12
*.cer
*.mobileprovision
*.provisionprofile
AuthKey_*.p8
.env
.env.*

# Local Claude Code context (personal notes — not synced)
CLAUDE.local.md
.claude/notes/
